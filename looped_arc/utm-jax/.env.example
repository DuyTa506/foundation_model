# Copy to .env and fill in your values. .env is gitignored.

# GCP project ID. If unset, scripts fall back to `gcloud config get-value project`.
# GCP_PROJECT=my-gcp-project

# Optional: GCS bucket for checkpoint storage. Used by scripts/upload_checkpoints.sh.
# GCS_CHECKPOINT_BUCKET=gs://my-bucket/utm-checkpoints

# Optional: default W&B project name (overrides train.py --project_name default).
# WANDB_PROJECT=utm-jax
